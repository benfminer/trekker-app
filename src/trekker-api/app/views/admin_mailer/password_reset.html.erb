<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <style>
      body { font-family: Inter, Arial, sans-serif; color: #333; max-width: 480px; margin: 0 auto; padding: 24px; }
      .button { display: inline-block; padding: 12px 24px; background: #FF6B00; color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; margin: 16px 0; }
      .footer { margin-top: 32px; font-size: 12px; color: #888; }
    </style>
  </head>
  <body>
    <p>Hi <%= @admin.display_name.presence || @admin.username %>,</p>

    <p>Someone requested a password reset for your TRACE Trekkers admin account.</p>

    <a href="<%= @reset_url %>" class="button">Reset My Password</a>

    <p>Or copy this link into your browser:<br>
    <small><%= @reset_url %></small></p>

    <p>This link expires in <strong><%= @expires_in %></strong>. If you didn't request a reset, you can safely ignore this email — your password has not changed.</p>

    <div class="footer">— The TRACE Trekkers Team</div>
  </body>
</html>
